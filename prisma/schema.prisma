// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled URL (e.g. Supabase port 6543): append ?pgbouncer=true to avoid
  // Postgres 42P05 "prepared statement already exists" with PgBouncer.
  url       = env("DATABASE_URL")
  // Direct Postgres URL (e.g. port 5432) — used by prisma migrate / db push
  directUrl = env("DIRECT_URL")
}

// Admin users who manage members and invitations
model Admin {
  id        String                  @id @default(cuid())
  name      String
  email     String                  @unique
  password  String
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  invitations        Invitations[]
  creditTransactions CreditTransaction[]

  @@map("Admin")
}

// Members who can send invitations
model Member {
  id              String                @id @default(cuid())
  name            String
  email           String                @unique
  whatsapp        String
  password        String
  creditPoints    Int                   @default(0)
  status          String                @default("active") // 'active' | 'inactive'
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  invitations          Invitations[]
  invitationMessages   InvitationMessages[]
  invitationSends      InvitationSends[]
  creditTransactions   CreditTransaction[]

  @@map("Member")
}

// Invitations created by admin
model Invitations {
  id                String                @id @default(cuid())
  title             String
  eventName         String
  eventDate         DateTime
  location          String
  invitationLink    String
  invitationDomain  String                // 'satumomen' | 'akainvitation'
  templateMessage   String
  costPoints        Int                   @default(20)
  status            String                @default("draft") // 'draft' | 'published' | 'completed'
  createdById       String
  assignedMemberId  String
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  createdBy         Admin               @relation(fields: [createdById], references: [id])
  assignedMember    Member              @relation(fields: [assignedMemberId], references: [id])
  invitationMessages InvitationMessages[]
  invitationSends     InvitationSends[]
  creditTransactions  CreditTransaction[]

  @@index([assignedMemberId])
  @@index([createdById])
  @@index([status])
  @@map("Invitations")
}

// Custom message templates created by member
model InvitationMessages {
  id              String        @id @default(cuid())
  memberId        String
  invitationId    String
  messageTemplate String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  member     Member     @relation(fields: [memberId], references: [id])
  invitation Invitations @relation(fields: [invitationId], references: [id])

  @@unique([memberId, invitationId])
  @@map("InvitationMessages")
}

// Log of invitations sent by member
model InvitationSends {
  id               String    @id @default(cuid())
  memberId         String
  invitationId     String
  guestName        String
  guestWhatsapp    String?
  guestEmail       String?
  generatedMessage String
  generatedLink    String
  sentAt           DateTime  @default(now())
  status           String    @default("pending") // 'pending' | 'sent' | 'failed'
  errorMessage     String?

  member     Member     @relation(fields: [memberId], references: [id])
  invitation Invitations @relation(fields: [invitationId], references: [id])

  @@index([memberId])
  @@index([invitationId])
  @@index([status])
  @@map("InvitationSends")
}

// Credit point transactions
model CreditTransaction {
  id           String     @id @default(cuid())
  memberId     String
  adminId      String?
  invitationId String?
  type         String     // 'credit' | 'debit'
  amount       Int
  description  String
  createdAt    DateTime   @default(now())

  member     Member      @relation(fields: [memberId], references: [id])
  admin      Admin?      @relation(fields: [adminId], references: [id])
  invitation Invitations? @relation(fields: [invitationId], references: [id])

  @@index([memberId])
  @@index([adminId])
  @@index([invitationId])
  @@map("CreditTransaction")
}
